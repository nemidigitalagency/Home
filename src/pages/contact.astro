---
import Layout from '../layouts/Layout.astro';
import { site } from '../config';

export const prerender = true;
---
<Layout
  title="Contact — Nemi Digital"
  description="Tell us about your project. We reply within 24 hours."
>
  <section class="relative min-h-screen pt-36 pb-24 overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
      <div class="blob h-[40rem] w-[40rem] bg-fuchsia-600/30" style="top:-20%;right:-10%"></div>
      <div class="blob h-[30rem] w-[30rem] bg-cyan-500/20" style="bottom:-20%;left:-10%"></div>
      <div class="absolute inset-0 bg-grid-faint [background-size:60px_60px] opacity-30 [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_70%)]"></div>
    </div>

    <div class="container-narrow">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-4 mb-8">
        <a href="/" class="text-white/40 hover:text-white text-xs font-mono uppercase tracking-[0.25em]">← Back</a>
        <span class="text-white/20">/</span>
        <span class="text-xs font-mono uppercase tracking-[0.25em] text-fuchsia-400">Contact</span>
      </div>

      <div class="grid gap-14 lg:grid-cols-5 lg:gap-20 items-start">
        <div class="lg:col-span-2 reveal-left">
          <span class="eyebrow">Let's talk</span>
          <h1 class="heading-xl mt-5">
            Tell us <br/>
            <span class="grad-text">everything.</span>
          </h1>
          <p class="subheading">
            About your brand, your goals, your budget, your timeline — even the messy parts. We read every message ourselves.
          </p>

          <div class="mt-12 space-y-6">
            <a href={`mailto:${site.email}`} data-cursor-hover class="flex items-center gap-4 group">
              <span class="h-14 w-14 rounded-2xl glass flex items-center justify-center text-fuchsia-400 group-hover:bg-fuchsia-500/20 transition group-hover:scale-110">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
              </span>
              <div>
                <p class="text-xs font-mono uppercase tracking-[0.2em] text-white/40">Email</p>
                <p class="text-white group-hover:text-fuchsia-400 transition text-base">{site.email}</p>
              </div>
            </a>

            <div class="flex items-center gap-4">
              <span class="h-14 w-14 rounded-2xl glass flex items-center justify-center text-cyan-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div>
                <p class="text-xs font-mono uppercase tracking-[0.2em] text-white/40">Based in</p>
                <p class="text-white text-base">{site.location}</p>
              </div>
            </div>

            {site.whatsapp && (
              <a href={`https://wa.me/${site.whatsapp.replace(/\D/g,'')}`} target="_blank" rel="noopener" data-cursor-hover class="flex items-center gap-4 group">
                <span class="h-14 w-14 rounded-2xl glass flex items-center justify-center text-green-400 group-hover:bg-green-500/20 transition group-hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.5.1-.8-.4-1.6-.9-2.3-1.5-.6-.6-1.1-1.3-1.5-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3zm-5.4 7.2h-.1c-1.6 0-3.2-.4-4.6-1.3l-.3-.2L4 21.3l1-3-.2-.3c-.9-1.4-1.4-3.1-1.4-4.8 0-4.6 3.8-8.3 8.4-8.3 2.2 0 4.3.9 5.9 2.5 1.6 1.6 2.4 3.7 2.4 5.9 0 4.6-3.7 8.3-8 8.3zm7-15.3C17.2 4.4 14.7 3.4 12 3.4 6.8 3.4 2.6 7.6 2.6 12.8c0 1.7.4 3.3 1.3 4.7L2.5 22l4.7-1.2c1.4.8 3 1.2 4.8 1.2 5.2 0 9.4-4.2 9.4-9.4 0-2.5-1-4.9-2.8-6.7z"/></svg>
                </span>
                <div>
                  <p class="text-xs font-mono uppercase tracking-[0.2em] text-white/40">WhatsApp</p>
                  <p class="text-white group-hover:text-green-400 transition text-base">{site.whatsapp}</p>
                </div>
              </a>
            )}
          </div>

          <!-- Response time promise -->
          <div class="mt-12 glass p-5 flex items-center gap-4">
            <span class="relative flex h-3 w-3">
              <span class="absolute inset-0 rounded-full bg-green-400 animate-ping opacity-75"></span>
              <span class="relative rounded-full h-3 w-3 bg-green-400"></span>
            </span>
            <p class="text-sm text-white/70"><span class="text-white font-semibold">We reply in under 24 hours</span> — usually much faster on weekdays.</p>
          </div>
        </div>

        <div class="lg:col-span-3 reveal-right">
          <form
            name="contact"
            method="POST"
            action="/api/contact"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="glass p-7 md:p-10 space-y-6 form"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="grid gap-6 sm:grid-cols-2">
              <div class="relative">
                <input required id="name" name="name" type="text" placeholder=" " class="peer w-full bg-white/5 border border-white/10 rounded-xl px-4 pt-6 pb-2 text-sm text-white focus:border-fuchsia-400 focus:outline-none transition placeholder-transparent" />
                <label for="name" class="absolute left-4 top-2 text-[10px] font-mono uppercase tracking-[0.2em] text-white/40 transition-all peer-focus:text-fuchsia-400 peer-placeholder-shown:top-4 peer-placeholder-shown:text-sm peer-placeholder-shown:font-sans peer-placeholder-shown:normal-case peer-placeholder-shown:tracking-normal peer-placeholder-shown:text-white/50">Your name</label>
              </div>
              <div class="relative">
                <input required id="email" name="email" type="email" placeholder=" " class="peer w-full bg-white/5 border border-white/10 rounded-xl px-4 pt-6 pb-2 text-sm text-white focus:border-fuchsia-400 focus:outline-none transition placeholder-transparent" />
                <label for="email" class="absolute left-4 top-2 text-[10px] font-mono uppercase tracking-[0.2em] text-white/40 transition-all peer-focus:text-fuchsia-400 peer-placeholder-shown:top-4 peer-placeholder-shown:text-sm peer-placeholder-shown:font-sans peer-placeholder-shown:normal-case peer-placeholder-shown:tracking-normal peer-placeholder-shown:text-white/50">Email</label>
              </div>
            </div>

            <div class="relative">
              <input id="company" name="company" type="text" placeholder=" " class="peer w-full bg-white/5 border border-white/10 rounded-xl px-4 pt-6 pb-2 text-sm text-white focus:border-fuchsia-400 focus:outline-none transition placeholder-transparent" />
              <label for="company" class="absolute left-4 top-2 text-[10px] font-mono uppercase tracking-[0.2em] text-white/40 transition-all peer-focus:text-fuchsia-400 peer-placeholder-shown:top-4 peer-placeholder-shown:text-sm peer-placeholder-shown:font-sans peer-placeholder-shown:normal-case peer-placeholder-shown:tracking-normal peer-placeholder-shown:text-white/50">Company / Brand (optional)</label>
            </div>

            <div class="relative">
              <select id="budget" name="budget" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 text-sm text-white focus:border-fuchsia-400 focus:outline-none transition appearance-none cursor-pointer">
                <option value="" class="bg-bg">Estimated budget...</option>
                <option value="under-50k" class="bg-bg">Under ₹50,000</option>
                <option value="50k-1l" class="bg-bg">₹50,000 – ₹1,00,000</option>
                <option value="1l-3l" class="bg-bg">₹1,00,000 – ₹3,00,000</option>
                <option value="3l+" class="bg-bg">Above ₹3,00,000</option>
                <option value="not-sure" class="bg-bg">Not sure yet</option>
              </select>
              <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/40">▾</span>
            </div>

            <div class="relative">
              <textarea required id="message" name="message" rows="5" placeholder=" " class="peer w-full bg-white/5 border border-white/10 rounded-xl px-4 pt-6 pb-2 text-sm text-white focus:border-fuchsia-400 focus:outline-none transition placeholder-transparent resize-none"></textarea>
              <label for="message" class="absolute left-4 top-2 text-[10px] font-mono uppercase tracking-[0.2em] text-white/40 transition-all peer-focus:text-fuchsia-400 peer-placeholder-shown:top-4 peer-placeholder-shown:text-sm peer-placeholder-shown:font-sans peer-placeholder-shown:normal-case peer-placeholder-shown:tracking-normal peer-placeholder-shown:text-white/50">Tell us about your project</label>
            </div>

            <button type="submit" data-cursor-hover class="btn-primary w-full !py-4 !text-base group">
              Send message
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>

            <p class="text-xs text-white/40 text-center">By submitting, you agree to our <a href="/privacy" class="underline hover:text-white">Privacy Policy</a>.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from 'gsap';
    // Floating label inputs have CSS peer states — nothing extra needed.
    // Success redirect same pattern
    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === '1') {
      const form = document.querySelector('form.form');
      if (form) form.outerHTML = '<div class="glass p-12 md:p-16 text-center"><div class="mx-auto h-20 w-20 rounded-full bg-gradient-to-br from-green-400 to-cyan-400 flex items-center justify-center mb-6 success-icon" style="transform:scale(0)"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div><h3 class="text-3xl font-display font-bold">Message sent!</h3><p class="mt-3 text-white/60 max-w-md mx-auto">Thanks for reaching out — we\'ll get back to you within 24 hours. Can\'t wait to hear what you\'re building.</p><a href="/" class="btn-primary mt-8 inline-flex">Back to home</a></div>';
      gsap.to('.success-icon', { scale: 1, duration: 0.6, ease: 'back.out(2)', delay: 0.2 });
    }
  </script>
</Layout>
