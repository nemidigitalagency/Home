---
import Layout from '../layouts/Layout.astro';
import { site } from '../config';

export const prerender = true;
---
<Layout title={`Terms — ${site.name}`} description="Terms of Service.">
  <section class="pt-36 pb-24 relative">
    <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
      <div class="blob h-[30rem] w-[30rem] bg-cyan-500/20" style="top:-20%;left:-10%"></div>
    </div>
    <article class="container-narrow max-w-3xl">
      <span class="eyebrow">Legal</span>
      <h1 class="heading mt-5">Terms of Service</h1>
      <p class="text-sm text-white/40 font-mono mt-4">Last updated: July 2026</p>

      <div class="mt-12 space-y-8 text-white/70 leading-relaxed text-[15px]">
        <div class="glass p-8">
          <h2 class="text-xl font-bold text-white mb-3 font-display">1. Acceptance</h2>
          <p>By accessing this website you agree to be bound by these Terms.</p>
        </div>
        <div class="glass p-8">
          <h2 class="text-xl font-bold text-white mb-3 font-display">2. No client relationship</h2>
          <p>Submitting a contact form does not create a client/agency relationship. An engagement begins only after both parties sign a statement of work.</p>
        </div>
        <div class="glass p-8">
          <h2 class="text-xl font-bold text-white mb-3 font-display">3. Intellectual property</h2>
          <p>All content on the site is owned by {site.name} or our clients. Case studies are shown with permission.</p>
        </div>
        <div class="glass p-8">
          <h2 class="text-xl font-bold text-white mb-3 font-display">4. Limitation of liability</h2>
          <p>The site is provided "as is". We are not liable for losses arising from inability to use the site.</p>
        </div>
        <div class="glass p-8">
          <h2 class="text-xl font-bold text-white mb-3 font-display">5. Governing law</h2>
          <p>These Terms are governed by the laws of India; jurisdiction in Uttar Pradesh.</p>
        </div>
        <div class="glass p-8">
          <h2 class="text-xl font-bold text-white mb-3 font-display">6. Contact</h2>
          <p>Questions? <a href={`mailto:${site.email}`} class="text-fuchsia-400 hover:underline">{site.email}</a>.</p>
        </div>
      </div>
    </article>
  </section>
</Layout>
