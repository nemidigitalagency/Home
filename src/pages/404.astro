---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found — Nemi Digital Agency" description="The page you're looking for doesn't exist.">
  <section class="section text-center">
    <div class="container-narrow max-w-xl">
      <p class="text-7xl sm:text-8xl font-extrabold font-display text-brand-600">404</p>
      <h1 class="heading mt-4">This page got lost in the build.</h1>
      <p class="subheading mx-auto">The page you're looking for doesn't exist or has moved. Let's get you back on track.</p>
      <div class="mt-8 flex gap-3 justify-center">
        <a href="/" class="btn-primary">Go home</a>
        <a href="/contact" class="btn-ghost">Contact us</a>
      </div>
    </div>
  </section>
</Layout>
