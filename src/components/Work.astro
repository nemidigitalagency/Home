---
import WorkCarousel from './WorkCarousel';
---
<section id="work" class="section relative">
  <div class="container-narrow mb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
    <div>
      <div class="flex items-center gap-4 mb-5">
        <span class="section-num">01 /</span>
        <span class="eyebrow">Selected Work</span>
      </div>
      <h2 class="heading">
        Projects that <span class="grad-text">shipped</span><br/>and <span class="grad-text">converted</span>.
      </h2>
      <p class="subheading">A rotating selection of our favourite launches. Hover or drag to explore — tap a card to open the case study.</p>
    </div>
    <div class="flex items-center gap-2 work-nav">
      <button class="work-prev h-12 w-12 rounded-full border border-white/15 bg-white/5 hover:bg-white/10 inline-flex items-center justify-center text-white/70 hover:text-white transition backdrop-blur-md" data-cursor-hover>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="work-next h-12 w-12 rounded-full border border-white/15 bg-white/5 hover:bg-white/10 inline-flex items-center justify-center text-white/70 hover:text-white transition backdrop-blur-md" data-cursor-hover>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <div class="px-2 md:px-0">
    <WorkCarousel client:only="react" />
  </div>

  <div class="container-narrow mt-10 flex justify-center">
    <div class="work-pagination !relative !w-auto flex gap-2"></div>
  </div>
</section>
