---
const marqueeWords = ['Astro','Next.js','React','Supabase','TanStack','Tailwind','GSAP','Netlify','Resend','Figma','Shopify','TypeScript'];
let marqueeHtml = '';
for (let i = 0; i < 2; i++) {
  for (const w of marqueeWords) {
    marqueeHtml += `<span class="text-white/10 hover:text-white transition">${w}</span><span class="text-fuchsia-400">✦</span>`;
  }
}
---
<section id="hero" class="relative min-h-screen flex items-center overflow-hidden pt-28 pb-20">
  <!-- =========== BACKGROUND: animated mesh gradient =========== -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <!-- Grid overlay -->
    <div class="absolute inset-0 bg-grid-faint [background-size:60px_60px] opacity-40 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_80%)]"></div>

    <!-- Animated blobs — each gets a GSAP timeline for infinite drift -->
    <div class="blob h-[40rem] w-[40rem] bg-fuchsia-500/40 blob-1" style="top:-10%;left:-10%;"></div>
    <div class="blob h-[35rem] w-[35rem] bg-violet-600/40 blob-2" style="top:30%;right:-5%;"></div>
    <div class="blob h-[30rem] w-[30rem] bg-cyan-400/30 blob-3" style="bottom:-15%;left:20%;"></div>
    <div class="blob h-[25rem] w-[25rem] bg-amber-400/25 blob-4" style="top:10%;left:45%;"></div>

    <!-- Vignette -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,rgba(7,7,12,0.6)_70%,rgba(7,7,12,1)_100%)]"></div>
  </div>

  <div class="container-narrow w-full relative z-10">
    <!-- Top meta row -->
    <div class="flex items-center justify-between mb-10 md:mb-16 hero-meta text-[11px] font-mono uppercase tracking-[0.3em] text-white/50">
      <div class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="absolute inset-0 rounded-full bg-green-400 animate-ping opacity-75"></span>
          <span class="relative rounded-full h-2 w-2 bg-green-400"></span>
        </span>
        <span>Available · Q3 2026</span>
      </div>
      <div class="hidden md:flex items-center gap-6">
        <span>25.4386° N</span>
        <span>78.5696° E</span>
        <span id="clock" class="text-fuchsia-300">--:--:--</span>
      </div>
    </div>

    <div class="grid gap-14 lg:grid-cols-12 items-center">
      <div class="lg:col-span-8">
        <div class="eyebrow mb-6">Premium digital studio · India</div>

        <h1 class="hero-title font-display font-bold text-white leading-[0.95]">
          <span class="block text-[clamp(2.5rem,8vw,7rem)]"><span class="hero-line" data-text="We build">We build</span></span>
          <span class="block text-[clamp(2.5rem,8vw,7rem)]"><span class="hero-line grad-text" data-text="cinematic">cinematic</span></span>
          <span class="block text-[clamp(2.5rem,8vw,7rem)]"><span class="hero-line" data-text="digital experiences.">digital experiences.</span></span>
        </h1>

        <p class="hero-sub max-w-xl mt-8 text-white/60 text-lg leading-relaxed">
          Nemi Digital is a boutique studio crafting
          <span class="text-white">fast, beautiful websites</span>,
          <span class="text-white">brands</span> and
          <span class="text-white">growth systems</span>
          for ambitious founders — from local jewellers to SaaS and D2C.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4 hero-cta">
          <a href="/contact" data-cursor-hover class="btn-primary">
            Start a project
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#work" data-cursor-hover class="btn-ghost group">
            <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-white/10 group-hover:bg-white/20 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
            </span>
            See our work
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 hero-stats">
          <div>
            <p class="text-3xl md:text-4xl font-display font-bold text-white counter" data-target="40">0</p>
            <p class="text-xs mt-2 text-white/40 uppercase tracking-wider">Happy clients</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-display font-bold text-white counter" data-target="98">0</p>
            <p class="text-xs mt-2 text-white/40 uppercase tracking-wider">Avg PageSpeed</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-display font-bold text-white counter" data-target="14">0</p>
            <p class="text-xs mt-2 text-white/40 uppercase tracking-wider">Days to launch</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-display font-bold text-white counter" data-target="3" data-suffix="+">0+</p>
            <p class="text-xs mt-2 text-white/40 uppercase tracking-wider">Years shipping</p>
          </div>
        </div>
      </div>

      <!-- Right column: floating orbit preview -->
      <div class="lg:col-span-4 hero-orbit relative h-[420px] hidden lg:block" id="hero-tilt">
        <!-- Outer ring -->
        <div class="orbit absolute inset-0 flex items-center justify-center">
          <div class="ring h-[400px] w-[400px] rounded-full border border-white/10 animate-[spin_30s_linear_infinite]"></div>
        </div>
        <div class="orbit absolute inset-0 flex items-center justify-center">
          <div class="ring h-[300px] w-[300px] rounded-full border border-dashed border-white/10 animate-[spin_45s_linear_infinite_reverse]"></div>
        </div>
        <div class="orbit absolute inset-0 flex items-center justify-center">
          <div class="ring h-[200px] w-[200px] rounded-full border border-white/15"></div>
        </div>

        <!-- Center card: live preview mock -->
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="preview-card relative w-[260px] rounded-2xl border border-white/15 bg-gradient-to-br from-white/10 to-white/0 p-3 backdrop-blur-2xl shadow-glow">
            <div class="flex items-center gap-1.5 pb-2 border-b border-white/10">
              <span class="h-2 w-2 rounded-full bg-red-400/80"></span>
              <span class="h-2 w-2 rounded-full bg-amber-400/80"></span>
              <span class="h-2 w-2 rounded-full bg-green-400/80"></span>
              <span class="ml-2 text-[9px] text-white/50 font-mono truncate">nemi.digital</span>
            </div>
            <div class="pt-3 space-y-2">
              <div class="h-6 w-3/4 rounded-md bg-gradient-to-r from-fuchsia-500 to-violet-500 animate-pulse"></div>
              <div class="h-2 w-full rounded bg-white/10"></div>
              <div class="h-2 w-5/6 rounded bg-white/10"></div>
              <div class="h-2 w-2/3 rounded bg-white/10"></div>
              <div class="grid grid-cols-3 gap-2 pt-2">
                <div class="h-14 rounded-lg bg-gradient-to-br from-fuchsia-500/70 to-pink-500/70"></div>
                <div class="h-14 rounded-lg bg-gradient-to-br from-violet-500/70 to-cyan-500/60"></div>
                <div class="h-14 rounded-lg bg-gradient-to-br from-cyan-400/60 to-amber-400/60"></div>
              </div>
              <div class="flex gap-2 pt-1">
                <div class="h-6 w-16 rounded-full bg-gradient-to-r from-fuchsia-500 to-violet-500"></div>
                <div class="h-6 w-12 rounded-full bg-white/10"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating stat chips orbiting the center -->
        <div class="chip absolute top-4 left-0 glass px-4 py-2.5 text-xs flex items-center gap-2" data-cursor-hover>
          <span class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-white/80">98 / 100 PageSpeed</span>
        </div>
        <div class="chip absolute bottom-16 -left-2 glass px-4 py-2.5 text-xs flex items-center gap-2" data-cursor-hover>
          <span class="text-fuchsia-400">★★★★★</span>
          <span class="text-white/80">40+ happy clients</span>
        </div>
        <div class="chip absolute top-1/2 -right-3 glass px-4 py-2.5 text-xs flex items-center gap-2" data-cursor-hover>
          <span>🚀</span><span class="text-white/80">Shipped in 14 days</span>
        </div>
        <div class="chip absolute bottom-4 right-8 glass px-4 py-2.5 text-xs flex items-center gap-2" data-cursor-hover>
          <span>💜</span><span class="text-white/80">Boutique studio</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[10px] font-mono tracking-[0.3em] uppercase text-white/40">
    <span>Scroll</span>
    <span class="relative block w-px h-10 overflow-hidden bg-white/10">
      <span class="scroll-line absolute top-0 left-0 w-full h-1/2 bg-white/80"></span>
    </span>
  </div>
</section>

<!-- =========== Marquee: tech we use =========== -->
<section class="py-8 border-y border-white/10 overflow-hidden bg-white/[0.02]">
  <div class="marquee">
    <div class="marquee-track text-3xl md:text-5xl font-display font-bold" set:html={marqueeHtml}></div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  // --- Live clock ---
  const clock = document.getElementById('clock');
  if (clock) {
    const tick = () => {
      const d = new Date();
      clock.textContent = d.toLocaleTimeString('en-GB', { hour12: false }) + ' IST';
    };
    tick();
    setInterval(tick, 1000);
  }

  // --- Drifting blobs (hero background mesh that moves like liquid) ---
  const blobs = document.querySelectorAll('#hero .blob');
  const blobTls = gsap.utils.toArray(blobs).map((blob, i) => {
    const tl = gsap.timeline({ repeat: -1, yoyo: true });
    const dur = 8 + i * 2;
    tl.to(blob, { xPercent: 20 + i * 8, yPercent: 15 + i * 6, scale: 1.15, rotation: i * 25, duration: dur, ease: 'sine.inOut' })
      .to(blob, { xPercent: -15 - i * 5, yPercent: -10, scale: 0.9, rotation: -i * 15, duration: dur + 2, ease: 'sine.inOut' })
      .to(blob, { xPercent: 10, yPercent: 20, scale: 1.1, duration: dur, ease: 'sine.inOut' });
    return tl;
  });

  // --- Hero entrance timeline ---
  const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  heroTl
    .from('.hero-meta > *', { opacity: 0, y: 20, stagger: 0.1, duration: 0.7 }, 0.2)
    .from('.hero-line', {
      yPercent: 120,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: 'power4.out',
    }, 0.4)
    .from('.hero-sub', { opacity: 0, y: 30, duration: 0.8 }, 1.0)
    .from('.hero-cta > *', { opacity: 0, y: 20, scale: 0.9, stagger: 0.1, duration: 0.6 }, 1.2)
    .from('.hero-stats > *', { opacity: 0, y: 30, stagger: 0.08, duration: 0.6 }, 1.4)
    .from('.hero-orbit .ring', { opacity: 0, scale: 0.3, stagger: 0.15, duration: 1, ease: 'back.out(1.6)' }, 0.8)
    .from('.preview-card', { opacity: 0, scale: 0.7, rotation: -10, duration: 1.2, ease: 'elastic.out(1,0.7)' }, 1.0)
    .from('.chip', { opacity: 0, y: (i) => [20, -30, 30, -20][i] || 20, x: (i) => [-20, 20, 20, -20][i] || -20, stagger: 0.1, duration: 0.8 }, 1.4)
    .from('.scroll-line', { yPercent: -100, duration: 1.5, repeat: -1, ease: 'none' }, 2);

  // --- Counters ---
  document.querySelectorAll('.counter').forEach((el) => {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const suffix = el.getAttribute('data-suffix') || '';
    const obj = { val: 0 };
    gsap.to(obj, {
      val: target,
      duration: 2,
      delay: 1.6,
      ease: 'power2.out',
      onUpdate: () => { el.textContent = Math.round(obj.val) + suffix; },
    });
  });

  // --- Pointer parallax on hero orbit (desktop only) ---
  const orbit = document.getElementById('hero-tilt');
  if (orbit && window.matchMedia('(hover:hover) and (pointer:fine)').matches) {
    const preview = orbit.querySelector('.preview-card');
    const chips = orbit.querySelectorAll('.chip');
    const rings = orbit.querySelectorAll('.ring');
    window.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      if (preview) gsap.to(preview, { rotateY: x * 8, rotateX: -y * 8, x: x * 10, y: y * 10, duration: 0.8, ease: 'power2.out' });
      chips.forEach((c, i) => {
        const d = (i + 1) * 8;
        gsap.to(c, { x: x * d, y: y * d, duration: 0.8, ease: 'power2.out' });
      });
      rings.forEach((r, i) => {
        const d = (i + 1) * 3;
        gsap.to(r, { x: x * d, y: y * d, duration: 1.2, ease: 'power2.out' });
      });
    });
  }
</script>
