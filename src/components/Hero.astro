---
// Hero section uses a subtle gradient + floating card for visual interest (SVG-only, no images needed).
---
<section class="relative overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div class="absolute -top-40 -left-40 h-[28rem] w-[28rem] rounded-full bg-brand-200/50 blur-3xl"></div>
    <div class="absolute top-1/3 -right-32 h-[22rem] w-[22rem] rounded-full bg-accent-500/20 blur-3xl"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(139,92,246,0.08),transparent_60%)]"></div>
  </div>

  <div class="container-narrow py-24 sm:py-32 grid gap-14 lg:grid-cols-2 lg:items-center">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
        <span class="h-2 w-2 rounded-full bg-brand-500 animate-pulse"></span>
        Accepting new projects
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] text-ink-900">
        Websites & growth systems that
        <span class="text-brand-600">actually convert</span>.
      </h1>
      <p class="mt-6 text-lg text-ink-500 max-w-xl">
        Nemi Digital Agency is a small, senior team designing and building fast, beautiful
        websites, e-commerce stores and internal tools — delivered on time, without agency bloat.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Start a project →</a>
        <a href="/#work" class="btn-ghost">See our work</a>
      </div>

      <div class="mt-10 flex items-center gap-6 text-sm text-ink-500">
        <div class="flex -space-x-2">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-brand-600 text-white text-xs font-bold ring-2 ring-white">JD</span>
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent-500 text-white text-xs font-bold ring-2 ring-white">RS</span>
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink-700 text-white text-xs font-bold ring-2 ring-white">AK</span>
        </div>
        <p>Trusted by <span class="font-semibold text-ink-900">40+ brands</span> across jewellery, SaaS & local businesses.</p>
      </div>
    </div>

    <!-- Floating preview card -->
    <div class="relative">
      <div class="relative rounded-2xl border border-ink-200 bg-white shadow-soft p-4 rotate-1">
        <div class="flex items-center gap-1.5 pb-3 border-b border-ink-100">
          <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
          <span class="ml-3 text-xs text-ink-500">bundelkhandjwellery.netlify.app</span>
        </div>
        <div class="pt-4 space-y-3">
          <div class="h-8 w-2/3 rounded-md bg-brand-100"></div>
          <div class="h-3 w-full rounded bg-ink-100"></div>
          <div class="h-3 w-5/6 rounded bg-ink-100"></div>
          <div class="grid grid-cols-3 gap-3 pt-2">
            <div class="h-20 rounded-lg bg-gradient-to-br from-brand-100 to-brand-200"></div>
            <div class="h-20 rounded-lg bg-gradient-to-br from-accent-100 to-accent-200"></div>
            <div class="h-20 rounded-lg bg-gradient-to-br from-ink-100 to-ink-200"></div>
          </div>
          <div class="flex justify-between pt-2">
            <div class="h-8 w-24 rounded-full bg-brand-600"></div>
            <div class="h-8 w-20 rounded-full bg-ink-100"></div>
          </div>
        </div>
      </div>

      <div class="absolute -bottom-6 -left-6 rounded-2xl bg-white shadow-soft border border-ink-200 p-4 -rotate-3 hidden sm:block">
        <div class="flex items-center gap-3">
          <div class="h-10 w-10 rounded-full bg-green-100 text-green-700 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <div>
            <p class="text-xs text-ink-500">PageSpeed</p>
            <p class="text-sm font-bold text-ink-900">98 / 100</p>
          </div>
        </div>
      </div>

      <div class="absolute -top-5 -right-4 rounded-2xl bg-white shadow-soft border border-ink-200 p-4 rotate-2 hidden sm:block">
        <p class="text-xs text-ink-500">Launched in</p>
        <p class="text-lg font-extrabold text-ink-900">3 weeks</p>
      </div>
    </div>
  </div>
</section>
